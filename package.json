{
  "name": "node-tarea",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "start": "node ./bin/www" ,
    "start:dev": "nodemon ./bin/www",
    "test": "jest"
  },
  "dependencies": {
    "cookie-parser": "~1.4.4",
    "debug": "~2.6.9",
    "express": "~4.22.1",
    "http-errors": "~1.6.3",
    "morgan": "~1.10.0",
    "pug": "~3.0.3"
  },
  "devDependencies": {
    "nodemon": "^3.1.14",
    "jest": "^29.6.1",
    "jest-junit": "^13.0.0"
  }
  ,
  "jest": {
    "testEnvironment": "node",
    "collectCoverage": true,
    "coverageDirectory": "coverage",
