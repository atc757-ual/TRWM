extends layout

block content
  .row.banner 
    .col-12
      h1= title 
  .row
    .col-12.col-lg-9
      form(action=formAction || `/location/${locationid}/review/new`, method='POST')
        .form-group 
          label(for='name') Name 
          input.form-control(type='text', id="name", name="name", placeholder='Name', value=(review && review.author) || '')
        .form-group 
          label(for='rating') Rating 
          select.form-control(id="rating", name="rating")
            option(value='5', selected=((review && review.rating === 5) ? true : undefined)) 5
            option(value='4', selected=((review && review.rating === 4) ? true : undefined)) 4
            option(value='3', selected=((review && review.rating === 3) ? true : undefined)) 3
            option(value='2', selected=((review && review.rating === 2) ? true : undefined)) 2
            option(value='1', selected=((review && review.rating === 1) ? true : undefined)) 1
        .form-group 
          label(for='review') Review 
          textarea.form-control(rows='5', id="review", name="review", placeholder='Write your review here') #{(review && review.reviewText) || ''}
        button.btn.btn-primary.mb-3(type='submit')= submitLabel || 'Submit Review'
        