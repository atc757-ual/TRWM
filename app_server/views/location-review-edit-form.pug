extends layout

block content
  .row.banner
    .col-12
      h1 Edit Review
  .row
    .col-12.col-lg-9
      form(action=`/location/${locationid}/review/${reviewid}/edit`, method='POST')
        .form-group
          label(for='name') Name
          input.form-control(type='text', id='name', name='name', value=review.author, placeholder='Name')
        .form-group
          label(for='rating') Rating
          select.form-control(id='rating', name='rating')
            option(value='5', selected=review.rating === 5) 5
            option(value='4', selected=review.rating === 4) 4
            option(value='3', selected=review.rating === 3) 3
            option(value='2', selected=review.rating === 2) 2
            option(value='1', selected=review.rating === 1) 1
        .form-group
          label(for='review') Review
          textarea.form-control(rows='5', id='review', name='review', placeholder='Write your review here')= review.reviewText
        button.btn.btn-primary.mb-3(type='submit') Update Review
        a.btn.btn-link.mb-3(href=`/location/${locationid}`) Cancel