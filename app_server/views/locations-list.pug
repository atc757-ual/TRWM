extends layout
include sharedHTMLfunctions

block content
  .row.banner 
    .col-12
      h1=pageHeader.title 
      small &nbsp; #{pageHeader.strapline} 
     
  .row
    .col-12.col-md-8 
     each location in locations
      .card.mt-4.mb-4
        .card-body 
          h4.card-title
            a(href=`/location/${location._id}`)= location.name
            small &nbsp;
              +starRating(location.rating)
            span.badge.badge-pill.badge-secondary.float-right #{location.distance || 'N/A'}   
          p.address #{location.address}
          .facilities 
          each facility in location.facilities
              span.badge.badge-warning  facility
              span.mr-1
          .mt-3
            a.btn.btn-outline-primary.btn-sm.mr-2(href=`/location/${location._id}/edit`) Edit
            form.d-inline(action=`/location/${location._id}/delete`, method='POST')
              button.btn.btn-danger.btn-sm(type='submit' onclick="return confirm('¿Estás seguro de que quieres eliminar esta ubicación y todas sus reseñas?')") Delete location
    .col-12.col-md-4
      .container.mb-3
        a.btn.btn-primary.btn-sm(href='/location/new') Add location
      .container
        p.lead Loc8r helps you find places to work when out and about. Perhaps with coffee, cake or a pint? Let Loc8r help you find
